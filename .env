# OAuth social login configuration for customer login
# Fill these values from Google Cloud Console and Meta for Developers
# Optional: custom secret to sign OAuth state (recommended)
# SOCIAL_STATE_SECRET=replace_with_a_long_random_secret

GOOGLE_CLIENT_ID=803376914160-dfokstj2263v1cu4kb6p7bd12elvs659.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
# Must match Google OAuth redirect URI exactly
GOOGLE_REDIRECT_URI=http://localhost/DoAnPHP/Login/social_login.php?provider=google&action=callback

FACEBOOK_CLIENT_ID=3567410323416529
FACEBOOK_CLIENT_SECRET=c3bf67a5ebfb44943a6f7bdf0e8d6b39
# Must match Facebook OAuth redirect URI exactly
FACEBOOK_REDIRECT_URI=http://localhost/DoAnPHP/Login/social_login.php?provider=facebook&action=callback
# Optional: permission scope for Facebook login.
# Use public_profile by default; when app is approved for email, set: public_profile,email
FACEBOOK_SCOPE=public_profile

